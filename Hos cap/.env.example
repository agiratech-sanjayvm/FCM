# === Application Settings ===
APP_NAME=Hospital Appointment System
DEBUG=False

# === PostgreSQL Database ===
# For Docker Compose, use: postgresql+asyncpg://postgres:postgres@db:5432/hospital_db
# For local development, use: postgresql+asyncpg://postgres:postgres@localhost:5432/hospital_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hospital_db

# === Firebase Cloud Messaging ===
# Path to Firebase service account JSON file
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json
